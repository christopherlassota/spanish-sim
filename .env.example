# Spanish Sim environment example
# Copy to .env and fill values as needed.

# Server
PORT=8787

# LLM (optional)
# If unset, app uses scripted fallback responses.
LLM_PROVIDER=openai

# OpenAI provider config (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# MiniMax provider config (used when LLM_PROVIDER=minimax)
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_BASE_URL=https://api.minimax.io/v1
