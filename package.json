{
  "name": "spanish-sim-mvp",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "start": "npm run build && node src/server.mjs",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch src/server.mjs",
    "dev:client": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
